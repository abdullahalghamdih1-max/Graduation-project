#include <Wire.h>
#include <LiquidCrystal_I2C.h>
#include <Stepper.h>
#include "SerialMP3Player.h"

// تعريف دبابيس مستشعر الألوان
#define S0 53
#define S1 52
#define S2 51
#define S3 50
#define sensorOut 49

// تعريف دبابيس محرك الاستبر (Stepper Motor)
#define stp 3
#define dir 4
#define MS1 5
#define MS2 6
#define EN 7

int steps_per_revolution = 200;
int microstepping = 8;
int angles = 0;

// إعداد وحدة الصوت MP3
#define TX 15 // TX pin for MP3 module
#define RX 14 // RX pin for MP3 module
SerialMP3Player mp3(RX, TX); 

// إعداد شاشة LCD
LiquidCrystal_I2C lcd(0x27, 16, 2);

int redFrequency = 0;
int greenFrequency = 0;
int blueFrequency = 0;

void setup() {
  Serial.begin(9600);
  
  // إعداد دبابيس مستشعر الألوان
  pinMode(S0, OUTPUT);
  pinMode(S1, OUTPUT);
  pinMode(S2, OUTPUT);
  pinMode(S3, OUTPUT);
  pinMode(sensorOut, INPUT);
  
  // ضبط تردد المستشعر إلى 20%
  digitalWrite(S0, HIGH);
  digitalWrite(S1, LOW);

  // إعداد دبابيس المحرك
  pinMode(stp, OUTPUT);
  pinMode(dir, OUTPUT);
  pinMode(MS1, OUTPUT);
  pinMode(MS2, OUTPUT);
  pinMode(EN, OUTPUT);
  digitalWrite(EN, HIGH); // إيقاف المحرك في البداية

  // تشغيل الشاشة
  lcd.init();
  lcd.backlight();

  // تشغيل وحدة MP3
  mp3.begin(9600);
  delay(500);
  mp3.sendCommand(CMD_SEL_DEV, 0, 2);
  delay(500);
}

void loop() {
  // قراءة اللون الأحمر
  digitalWrite(S2, LOW); digitalWrite(S3, LOW);
  redFrequency = pulseIn(sensorOut, LOW);
  
  // قراءة اللون الأخضر
  digitalWrite(S2, HIGH); digitalWrite(S3, HIGH);
  greenFrequency = pulseIn(sensorOut, LOW);
  
  // قراءة اللون الأزرق
  digitalWrite(S2, LOW); digitalWrite(S3, HIGH);
  blueFrequency = pulseIn(sensorOut, LOW);
  
  delay(500);

  // طباعة القيم على الـ Serial Monitor
  Serial.print("R: "); Serial.print(redFrequency);
  Serial.print(" | G: "); Serial.print(greenFrequency);
  Serial.print(" | B: "); Serial.println(blueFrequency);

  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("Color:");
  lcd.setCursor(0, 1);

  // اكتشاف اللون الأحمر
  if (redFrequency >= 160 && redFrequency <= 177 && greenFrequency >= 250 && greenFrequency <= 295 && blueFrequency >= 198 && blueFrequency <= 225) {
    Serial.println("Red");
    lcd.print("Red");
    mp3.play(1);
    angles = 15;
    motors();
    resetEDPins();
  }
  // اكتشاف اللون الأخضر (معدل بناءً على هيكل الكود)
  else if (redFrequency >= 200 && greenFrequency <= 150 && blueFrequency >= 200) { 
    Serial.println("Green");
    lcd.print("Green");
    mp3.play(2);
    delay(100);
    angles = 60;
    motors();
    resetEDPins();
  }
  // اكتشاف اللون الأصفر
  else if (redFrequency >= 113 && redFrequency <= 124 && greenFrequency >= 110 && greenFrequency <= 120) {
    Serial.println("Yellow");
    lcd.print("Yellow");
    mp3.play(7);
    delay(500);
    angles = 10;
    motors();
    resetEDPins();
  }
  // اكتشاف اللون البرتقالي
  else if (redFrequency >= 135 && redFrequency <= 148 && greenFrequency >= 170 && greenFrequency <= 188) {
    Serial.println("Orange");
    lcd.print("Orange");
    mp3.play(5);
    delay(100);
    angles = 60;
    motors();
    resetEDPins();
  }
  // اكتشاف اللون البنفسجي
  else if (redFrequency >= 305 && redFrequency <= 325 && blueFrequency >= 175 && blueFrequency <= 185) {
    Serial.println("Purple");
    lcd.print("Purple");
    mp3.play(6);
    delay(100);
    angles = 45; // زاوية افتراضية
    motors();
    resetEDPins();
  }
  // اكتشاف اللون الأسود
  else if (redFrequency >= 400 && greenFrequency >= 400 && blueFrequency >= 400) {
    Serial.println("Black");
    lcd.print("Black");
    mp3.play(4);
    delay(100);
    angles = 60;
    motors();
    resetEDPins();
  }
  // لون غير معروف
  else if (redFrequency >= 1800) {
    Serial.println("Unknown");
    lcd.print("Unknown");
  }

  delay(500);
}

void motors() {
  digitalWrite(EN, LOW); // تفعيل المحرك
  // حساب عدد الخطوات بناءً على الزاوية والميكروستيبنغ
  long total_steps = (long)angles * steps_per_revolution * microstepping / 360;
  
  digitalWrite(dir, HIGH);
  digitalWrite(MS1, HIGH);
  digitalWrite(MS2, HIGH);
  
  for (int i = 0; i < total_steps; i++) {digitalWrite(stp, HIGH);
    delayMicroseconds(850);
    digitalWrite(stp, LOW);
    delayMicroseconds(850);
  }
}

void resetEDPins() {
  digitalWrite(stp, LOW);
  digitalWrite(dir, LOW);
  digitalWrite(MS1, LOW);
  digitalWrite(MS2, LOW);
  digitalWrite(EN, HIGH); // إيقاف تفعيل المحرك للحفاظ على الطاقة
} 
